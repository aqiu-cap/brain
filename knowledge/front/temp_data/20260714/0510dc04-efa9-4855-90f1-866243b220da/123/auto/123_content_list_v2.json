            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "1 H3C LA2608 室内无线网关用户手册"
                    }
                ],
                "level": 2
            },
            "bbox": [
                92,
                60,
                613,
